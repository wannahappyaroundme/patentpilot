# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase direct DB connection (for Python ETL)
# Settings → Database → Connection string → URI (Session pooler 또는 Direct)
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# OpenAI (AI 채팅 코파일럿 + 거래 제안 메일 초안)
OPENAI_API_KEY=

# NTIS OpenAPI (PatentRank COM 축 — R&D 과제 매칭)
# 발급: https://www.ntis.go.kr/ — 인증키 신청 후 영업일 3~5일 대기
# 사용: python -m patentpilot_etl.ntis_enrich
NTIS_API_KEY=

# Admin (basic auth for /admin/*)
ADMIN_USER=
ADMIN_PASSWORD=

# Upstash Redis (레이트리밋 공유 저장소 — 미설정 시 인메모리 폴백)
# 발급: https://console.upstash.com → Redis → Create Database → REST API의 .env 탭
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Sentry 에러 추적 (DSN은 공개 식별자 — 미설정 시 no-op)
# 발급: https://sentry.io → 프로젝트(Next.js) → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
